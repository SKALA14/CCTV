# === OpenAI ===
OPENAI_API_KEY=sk-...

# === 영상 소스 ===
# "file" = 로컬 mp4, "rtsp" = RTSP 스트림
SOURCE_TYPE=file
SOURCE_PATH=/data/sample.mp4
# RTSP_URL=rtsp://mediamtx:8554/live  # SOURCE_TYPE=rtsp 시 사용

# === 샘플링 ===
SAMPLE_FPS=1.0

# === 스토리지 ===
FRAME_STORAGE_PATH=/frames

# === Redis ===
REDIS_URL=redis://redis:6379

# === PostgreSQL ===
DATABASE_URL=postgresql+asyncpg://cctv:cctv@postgres:5432/cctv

# === Frontend ===
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/events
